# Database Configuration
DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"

# Microsoft Outlook Integration
# Required for invoice email fetching from Outlook/Microsoft 365
# See docs/OUTLOOK_SETUP.md for detailed setup instructions

# Application (client) ID from Azure Portal
MICROSOFT_CLIENT_ID=your_application_client_id_here

# Client secret value from Azure Portal (Certificates & secrets)
MICROSOFT_CLIENT_SECRET=your_client_secret_value_here

# Directory (tenant) ID from Azure Portal
# Use "common" for multi-tenant or personal accounts
MICROSOFT_TENANT_ID=your_tenant_id_or_common

# OAuth redirect URI (must match Azure app registration)
# Replace YOUR_NETLIFY_SITE with your actual Netlify site name
MICROSOFT_REDIRECT_URI=https://YOUR_NETLIFY_SITE.netlify.app/.netlify/functions/outlook-auth

# Netlify Blobs Configuration
# Used for storing invoices and auth tokens
# Set to "production" for live site, "dev" for local testing
NETLIFY_BLOBS_CONTEXT=production

# Optional: Node environment
NODE_ENV=production
