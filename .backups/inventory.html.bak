<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Inventory — CTRC Club Manager</title>

  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <style>
    @font-face { font-family: 'Inter'; font-style: normal; font-weight: 400; font-display: block; src: url('fonts/inter-400.woff2') format('woff2'); }
    @font-face { font-family: 'Inter'; font-style: normal; font-weight: 500; font-display: block; src: url('fonts/inter-500.woff2') format('woff2'); }
    @font-face { font-family: 'Inter'; font-style: normal; font-weight: 600; font-display: block; src: url('fonts/inter-600.woff2') format('woff2'); }
    @font-face { font-family: 'Inter'; font-style: normal; font-weight: 700; font-display: block; src: url('fonts/inter-700.woff2') format('woff2'); }
    @font-face { font-family: 'Inter'; font-style: normal; font-weight: 800; font-display: block; src: url('fonts/inter-800.woff2') format('woff2'); }
    @font-face { font-family: 'Inter'; font-style: normal; font-weight: 900; font-display: block; src: url('fonts/inter-900.woff2') format('woff2'); }
  </style>

  <style>
    /* ── DESIGN TOKENS ─────────────────────────────── */
    :root {
      --yellow:      #F5D000;
      --yellow-dim:  #C8AA00;
      --yellow-bg:   #FFFBDC;
      --black:       #171717;
      --black-2:     #262626;
      --black-3:     #404040;
      --gray-1:      #737373;
      --gray-2:      #A3A3A3;
      --gray-3:      #D4D4D4;
      --gray-4:      #F5F5F5;
      --white:       #FFFFFF;
      --sidebar-w:   240px;
      --radius:      10px;
      --radius-sm:   6px;
      --shadow:      0 1px 3px rgba(0,0,0,.08), 0 1px 2px rgba(0,0,0,.05);
      --shadow-md:   0 4px 12px rgba(0,0,0,.10);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      background: var(--gray-4);
      color: var(--black);
      min-height: 100vh;
      display: flex;
    }

    /* ── SIDEBAR ───────────────────────────────────── */
    .sidebar {
      width: var(--sidebar-w);
      background: var(--black);
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0; left: 0; bottom: 0;
      z-index: 100;
    }
    .sidebar-logo { padding: 20px 18px 16px; border-bottom: 1px solid var(--black-3); }
    .sidebar-logo img { width: 140px; display: block; }
    .sidebar-logo-sub { font-size: 10px; color: var(--gray-2); letter-spacing: .08em; text-transform: uppercase; margin-top: 6px; }
    .sidebar-nav { flex: 1; padding: 12px 10px; display: flex; flex-direction: column; gap: 2px; }
    .nav-section-label { font-size: 10px; font-weight: 600; color: var(--gray-1); letter-spacing: .1em; text-transform: uppercase; padding: 10px 8px 4px; }
    .nav-item {
      display: flex; align-items: center; gap: 10px;
      padding: 8px 10px; border-radius: var(--radius-sm);
      color: var(--gray-2); font-size: 13.5px; font-weight: 500;
      cursor: pointer; transition: background .15s, color .15s;
      text-decoration: none; position: relative;
    }
    .nav-item:hover { background: var(--black-2); color: var(--white); }
    .nav-item.active { background: var(--yellow); color: var(--black); font-weight: 700; }
    .nav-item.active i { color: var(--black); }
    .nav-item i { width: 16px; height: 16px; }
    .nav-badge {
      margin-left: auto; background: var(--yellow); color: var(--black);
      font-size: 10px; font-weight: 700; padding: 1px 6px; border-radius: 99px;
    }
    .nav-item.active .nav-badge { background: var(--black); color: var(--yellow); }
    .sidebar-footer { padding: 14px 14px; border-top: 1px solid var(--black-3); }
    .sidebar-user { display: flex; align-items: center; gap: 10px; cursor: pointer; }
    .sidebar-avatar { width: 34px; height: 34px; border-radius: 50%; background: var(--yellow); display: flex; align-items: center; justify-content: center; overflow: hidden; flex-shrink: 0; }
    .sidebar-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .sidebar-user-name { font-size: 13px; font-weight: 600; color: var(--white); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .sidebar-user-role { font-size: 11px; color: var(--gray-2); }

    /* ── MAIN ──────────────────────────────────────── */
    .main { margin-left: var(--sidebar-w); flex: 1; min-width: 0; overflow-x: hidden; display: flex; flex-direction: column; min-height: 100vh; }

    /* ── TOPBAR ────────────────────────────────────── */
    .topbar {
      background: var(--white); border-bottom: 1px solid var(--gray-3);
      padding: 0 28px; height: 56px; display: flex; align-items: center;
      gap: 12px; position: sticky; top: 0; z-index: 50;
    }
    .breadcrumb { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--gray-1); }
    .breadcrumb a { color: var(--gray-1); text-decoration: none; }
    .breadcrumb a:hover { color: var(--black); }
    .breadcrumb-sep { color: var(--gray-3); }
    .breadcrumb-current { color: var(--black); font-weight: 600; }
    .search-wrap {
      display: flex; align-items: center; gap: 8px;
      background: var(--gray-4); border: 1px solid var(--gray-3);
      border-radius: var(--radius-sm); padding: 6px 12px;
      flex: 1; max-width: 380px; cursor: text;
    }
    .search-wrap input { border: none; background: transparent; font-size: 13px; color: var(--black); outline: none; width: 100%; font-family: 'Inter', sans-serif; }
    .search-wrap input::placeholder { color: var(--gray-2); }
    .search-kbd { font-size: 10px; color: var(--gray-2); background: var(--white); border: 1px solid var(--gray-3); border-radius: 4px; padding: 1px 5px; white-space: nowrap; }
    .topbar-right { margin-left: auto; display: flex; align-items: center; gap: 8px; }
    .btn { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 600; padding: 7px 14px; border-radius: var(--radius-sm); border: none; cursor: pointer; transition: opacity .15s, transform .1s; font-family: 'Inter', sans-serif; }
    .btn:active { transform: scale(.97); }
    .btn-yellow { background: var(--yellow); color: var(--black); }
    .btn-yellow:hover { opacity: .88; }
    .btn-outline { background: transparent; border: 1.5px solid var(--gray-3); color: var(--black-3); }
    .btn-outline:hover { border-color: var(--gray-2); }
    .icon-btn { width: 34px; height: 34px; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; border: 1.5px solid var(--gray-3); background: var(--white); cursor: pointer; color: var(--gray-1); transition: all .15s; position: relative; }
    .icon-btn:hover { border-color: var(--gray-2); color: var(--black); }
    .notif-dot { position: absolute; top: 5px; right: 5px; width: 7px; height: 7px; background: var(--yellow); border-radius: 50%; border: 1.5px solid var(--white); }

    /* ── CONTENT ───────────────────────────────────── */
    .content { padding: 28px; display: flex; flex-direction: column; gap: 20px; }
    .page-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
    .page-title { font-size: 22px; font-weight: 800; color: var(--black); letter-spacing: -.02em; }
    .page-subtitle { font-size: 13px; color: var(--gray-1); margin-top: 2px; }

    /* ── STAT CARDS ────────────────────────────────── */
    .stat-grid-4 {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
    }
    .stat-card {
      background: var(--white);
      border: 1px solid var(--gray-3);
      border-radius: var(--radius);
      padding: 16px 18px;
      display: flex;
      flex-direction: column;
      gap: 6px;
      box-shadow: var(--shadow);
      position: relative;
      overflow: hidden;
    }
    .stat-card.accent-yellow { border-top: 3px solid var(--yellow); }
    .stat-card.accent-red    { border-top: 3px solid #EF4444; }
    .stat-label { font-size: 10.5px; font-weight: 700; color: var(--gray-1); letter-spacing: .07em; text-transform: uppercase; }
    .stat-value { font-size: 28px; font-weight: 900; color: var(--black); letter-spacing: -.03em; line-height: 1; }
    .stat-meta { font-size: 11.5px; color: var(--gray-2); }
    .stat-icon { position: absolute; top: 14px; right: 14px; width: 30px; height: 30px; background: var(--gray-4); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; color: var(--gray-2); }
    .stat-icon.yellow-bg { background: var(--yellow-bg); color: var(--yellow-dim); }
    .stat-icon.red-bg    { background: #FEF2F2; color: #EF4444; }

    /* ── FILTER BAR ────────────────────────────────── */
    .filter-bar {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }
    .filter-chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      border-radius: var(--radius-sm);
      border: 1.5px solid var(--gray-3);
      background: var(--white);
      font-size: 12.5px;
      font-weight: 500;
      color: var(--black-3);
      cursor: pointer;
      transition: all .15s;
      user-select: none;
    }
    .filter-chip:hover { border-color: var(--gray-2); }
    .chip-label { font-weight: 700; color: var(--gray-1); font-size: 10px; text-transform: uppercase; letter-spacing: .06em; margin-right: 2px; }
    .filter-chip select {
      border: none; background: transparent; font-size: 12.5px;
      font-weight: 600; color: inherit; cursor: pointer; outline: none;
      font-family: 'Inter', sans-serif;
      appearance: none; padding-right: 2px;
    }
    .filter-sep { width: 1px; height: 20px; background: var(--gray-3); margin: 0 4px; }
    .clear-filters {
      display: inline-flex; align-items: center; gap: 5px;
      font-size: 12px; font-weight: 500; color: var(--gray-1);
      cursor: pointer; margin-left: auto;
    }
    .clear-filters:hover { color: var(--black); }

    /* ── CARD ──────────────────────────────────────── */
    .card {
      background: var(--white);
      border: 1px solid var(--gray-3);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow: hidden;
    }
    .card-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 14px 20px; border-bottom: 1px solid var(--gray-3);
    }
    .card-title { font-size: 14px; font-weight: 700; color: var(--black); }
    .card-meta { font-size: 12px; color: var(--gray-1); }

    /* ── TABLE ─────────────────────────────────────── */
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; }
    thead th {
      font-size: 11px; font-weight: 700; color: var(--gray-1);
      letter-spacing: .06em; text-transform: uppercase;
      text-align: left; padding: 10px 16px;
      border-bottom: 1px solid var(--gray-3);
      background: var(--gray-4);
      white-space: nowrap;
    }
    tbody tr {
      border-bottom: 1px solid var(--gray-3);
      transition: background .1s;
      position: relative;
    }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: var(--yellow-bg); }
    td { padding: 11px 16px; font-size: 13px; color: var(--black-3); vertical-align: middle; }

    /* item name cell */
    .item-name { font-size: 13.5px; font-weight: 700; color: var(--black); }
    .item-sku   { font-size: 11px; color: var(--gray-2); margin-top: 1px; }

    /* category pill */
    .cat-pill {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 2px 8px; border-radius: 99px;
      font-size: 11px; font-weight: 600;
      background: var(--gray-4); color: var(--black-3);
      border: 1px solid var(--gray-3);
      white-space: nowrap;
    }

    /* status badges */
    .badge {
      display: inline-flex; align-items: center; gap: 4px;
      font-size: 11px; font-weight: 700;
      padding: 3px 9px; border-radius: 99px;
      white-space: nowrap;
    }
    .badge-in-stock  { background: #F0FDF4; color: #15803D; }
    .badge-low       { background: var(--yellow-bg); color: #92700A; border: 1px solid #F5D00055; }
    .badge-out       { background: #FEF2F2; color: #DC2626; border: 1px solid #FECACA; font-weight: 900; }

    /* qty cell */
    .qty-cell { font-size: 13px; font-weight: 700; color: var(--black); }
    .qty-low  { color: #D97706; }
    .qty-zero { color: #DC2626; }
    .min-qty  { font-size: 11px; color: var(--gray-2); margin-top: 1px; }

    /* team chip */
    .team-chip {
      display: inline-flex; align-items: center; gap: 4px;
      font-size: 11px; font-weight: 700;
      padding: 2px 7px; border-radius: 4px;
      background: var(--black); color: var(--white);
    }
    .team-chip.shared { background: var(--gray-3); color: var(--black-3); }

    /* actions col */
    .row-actions { display: flex; align-items: center; gap: 4px; }
    .reorder-btn {
      display: none;
      align-items: center; gap: 4px;
      font-size: 11px; font-weight: 700;
      padding: 4px 10px; border-radius: var(--radius-sm);
      border: 1.5px solid var(--yellow);
      background: var(--yellow-bg);
      color: var(--black);
      cursor: pointer;
      transition: all .15s;
      white-space: nowrap;
    }
    .reorder-btn:hover { background: var(--yellow); }
    tbody tr:hover .reorder-btn { display: inline-flex; }
    .more-btn {
      display: inline-flex; align-items: center; justify-content: center;
      width: 28px; height: 28px;
      border-radius: var(--radius-sm);
      border: 1.5px solid var(--gray-3);
      background: var(--white);
      color: var(--gray-1);
      cursor: pointer;
      transition: all .15s;
    }
    .more-btn:hover { border-color: var(--black); color: var(--black); }

    /* out-of-stock row tint */
    tbody tr.oos-row:hover { background: #FEF2F2; }
    tbody tr.oos-row td.qty-cell-wrap { color: #DC2626; }

    /* ── CAUTION STRIP ─────────────────────────────── */
    .caution-strip {
      height: 5px;
      background: repeating-linear-gradient(-55deg, var(--yellow) 0, var(--yellow) 10px, var(--black) 10px, var(--black) 20px);
      opacity: .15;
    }

    /* ── PAGINATION ────────────────────────────────── */
    .pagination {
      display: flex; align-items: center; justify-content: space-between;
      padding: 12px 20px; border-top: 1px solid var(--gray-3);
      background: var(--white);
    }
    .pagination-info { font-size: 12.5px; color: var(--gray-1); }
    .pagination-btns { display: flex; gap: 4px; }
    .page-btn {
      width: 30px; height: 30px; border-radius: var(--radius-sm);
      display: flex; align-items: center; justify-content: center;
      border: 1.5px solid var(--gray-3); background: var(--white);
      font-size: 12px; font-weight: 600; cursor: pointer;
      transition: all .15s; color: var(--black-3);
      font-family: 'Inter', sans-serif;
    }
    .page-btn:hover { border-color: var(--gray-2); }
    .page-btn.active { background: var(--yellow); border-color: var(--yellow); color: var(--black); }
    .page-btn:disabled { opacity: .4; cursor: not-allowed; }

    /* ── RESPONSIVE ────────────────────────────────── */
    @media (max-width: 1100px) {
      .stat-grid-4 { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 768px) {
      .content { padding: 16px; }
      .stat-grid-4 { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</head>

<body>

<!-- ═══════════════ SIDEBAR ═══════════════ -->
<aside class="sidebar">
  <div class="sidebar-logo">
    <img src="logo-white.png" alt="Caution Tape Robotics" />
    <div class="sidebar-logo-sub">Club Manager</div>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-section-label">General</div>
    <a class="nav-item" href="index.html">
      <i data-lucide="layout-dashboard"></i> Dashboard
    </a>
    <a class="nav-item" href="students.html">
      <i data-lucide="users"></i> Students
    </a>
    <a class="nav-item" href="foundation.html">
      <i data-lucide="book-open"></i> Foundation
    </a>
    <a class="nav-item" href="teams.html">
      <i data-lucide="cpu"></i> Teams
    </a>
    <a class="nav-item" href="tasks.html">
      <i data-lucide="circle-check"></i> Tasks
      <span class="nav-badge">5</span>
    </a>
    <a class="nav-item" href="projects.html">
      <i data-lucide="folder"></i> Projects
    </a>

    <div class="nav-section-label" style="margin-top:8px;">Competition</div>
    <a class="nav-item" href="https://matchsight.ct839.com/events?programId=1" target="_blank">
      <i data-lucide="trophy"></i> Competitions
    </a>

    <div class="nav-section-label" style="margin-top:8px;">Operations</div>
    <a class="nav-item active" href="inventory.html">
      <i data-lucide="package"></i> Inventory
    </a>
    <a class="nav-item" href="purchases.html">
      <i data-lucide="receipt"></i> Purchases
    </a>
    <a class="nav-item" href="purchases-invoices.html">
      <i data-lucide="file-text"></i> Invoices
    </a>
    <a class="nav-item" href="reports.html">
      <i data-lucide="bar-chart-2"></i> Reports
    </a>
    <div style="margin-top:auto;"></div>
    <a class="nav-item" href="#">
      <i data-lucide="settings"></i> Settings
    </a>
  </nav>

  <div class="sidebar-footer">
    <div class="sidebar-user">
      <div class="sidebar-avatar">
        <img src="icon-white.png" alt="User" />
      </div>
      <div style="flex:1;min-width:0;">
        <div class="sidebar-user-name">Malhar Soni</div>
        <div class="sidebar-user-role">Head Coach</div>
      </div>
      <i data-lucide="chevron-up" style="width:14px;height:14px;color:#737373;flex-shrink:0;"></i>
    </div>
  </div>
</aside>

<!-- ═══════════════ MAIN ═══════════════ -->
<div class="main">

  <!-- TOPBAR -->
  <header class="topbar">
    <div class="breadcrumb">
      <a href="index.html">Dashboard</a>
      <span class="breadcrumb-sep"><i data-lucide="chevron-right" style="width:13px;height:13px;"></i></span>
      <span class="breadcrumb-current">Inventory</span>
    </div>
    <div class="search-wrap" style="margin-left:16px;">
      <i data-lucide="search" style="width:14px;height:14px;color:#A3A3A3;flex-shrink:0;"></i>
      <input type="text" id="inv-search" placeholder="Search items, category, SKU…" oninput="applyFilters()" />
      <span class="search-kbd">⌘K</span>
    </div>
    <div class="topbar-right">
      <button class="btn btn-outline" onclick="exportInventoryCSV()">
        <i data-lucide="download" style="width:13px;height:13px;"></i>
        Export CSV
      </button>
      <button class="btn btn-yellow" onclick="openAddItem()">
        <i data-lucide="plus" style="width:13px;height:13px;"></i>
        Add Item
      </button>
      <div class="icon-btn" onclick="openNotifPanel()" style="position:relative;cursor:pointer;">
        <i data-lucide="bell" style="width:15px;height:15px;"></i>
        <span class="notif-dot"></span>
      </div>
    </div>
  </header>

  <!-- PAGE CONTENT -->
  <main class="content">

    <!-- PAGE HEADER -->
    <div class="page-header">
      <div>
        <div class="page-title">Inventory</div>
        <div class="page-subtitle">Track robot parts, tools, and supplies across all teams.</div>
      </div>
    </div>

    <!-- STAT CARDS -->
    <div class="stat-grid-4">
      <div class="stat-card accent-yellow">
        <div class="stat-icon yellow-bg"><i data-lucide="package" style="width:15px;height:15px;"></i></div>
        <div class="stat-label">Total Items</div>
        <div class="stat-value">847</div>
        <div class="stat-meta">Across all categories</div>
      </div>
      <div class="stat-card accent-red">
        <div class="stat-icon red-bg"><i data-lucide="triangle-alert" style="width:15px;height:15px;"></i></div>
        <div class="stat-label">Low Stock</div>
        <div class="stat-value" style="color:#D97706;">12</div>
        <div class="stat-meta" style="color:#D97706;">Needs reorder soon</div>
      </div>
      <div class="stat-card accent-red">
        <div class="stat-icon red-bg"><i data-lucide="x-circle" style="width:15px;height:15px;"></i></div>
        <div class="stat-label">Out of Stock</div>
        <div class="stat-value" style="color:#DC2626;">3</div>
        <div class="stat-meta" style="color:#DC2626;">Order immediately</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon yellow-bg"><i data-lucide="dollar-sign" style="width:15px;height:15px;"></i></div>
        <div class="stat-label">Estimated Value</div>
        <div class="stat-value" style="font-size:22px;margin-top:4px;">$4,280</div>
        <div class="stat-meta">Replacement cost</div>
      </div>
    </div>

    <!-- FILTER BAR -->
    <div class="filter-bar">
      <div class="filter-chip">
        <span class="chip-label">Category</span>
        <select id="filter-cat" onchange="applyFilters()">
          <option value="">All</option>
          <option value="Motors &amp; Electronics">Motors &amp; Electronics</option>
          <option value="Structure">Structure</option>
          <option value="Wheels &amp; Drivetrain">Wheels &amp; Drivetrain</option>
          <option value="Pneumatics">Pneumatics</option>
          <option value="Tools">Tools</option>
          <option value="Consumables">Consumables</option>
          <option value="Sensors">Sensors</option>
        </select>
        <i data-lucide="chevron-down" style="width:12px;height:12px;"></i>
      </div>

      <div class="filter-chip">
        <span class="chip-label">Status</span>
        <select id="filter-status" onchange="applyFilters()">
          <option value="">All</option>
          <option value="In Stock">In Stock</option>
          <option value="Low Stock">Low Stock</option>
          <option value="Out of Stock">Out of Stock</option>
        </select>
        <i data-lucide="chevron-down" style="width:12px;height:12px;"></i>
      </div>

      <div class="filter-chip">
        <span class="chip-label">Team</span>
        <select id="filter-team" onchange="applyFilters()">
          <option value="">All Teams</option>
          <option value="839Z">839Z</option>
          <option value="839Y">839Y</option>
          <option value="839X">839X</option>
          <option value="839Z">839Z</option>
          <option value="Shared">Shared</option>
        </select>
        <i data-lucide="chevron-down" style="width:12px;height:12px;"></i>
      </div>

      <div class="filter-sep"></div>

      <div class="clear-filters" onclick="clearFilters()">
        <i data-lucide="x" style="width:12px;height:12px;"></i>
        Clear filters
      </div>

      <div id="active-filter-count" style="display:none;margin-left:4px;">
        <span style="background:var(--yellow);color:var(--black);font-size:10px;font-weight:700;padding:2px 7px;border-radius:99px;" id="filter-count-badge">0</span>
      </div>
    </div>

    <!-- INVENTORY TABLE CARD -->
    <div class="card">
      <div class="card-header">
        <div>
          <span class="card-title">All Items</span>
          <span class="card-meta" id="row-count" style="margin-left:10px;"></span>
        </div>
        <div style="display:flex;gap:6px;align-items:center;">
          <span style="font-size:12px;color:var(--gray-1);">
            <span style="display:inline-flex;align-items:center;gap:4px;">
              <span style="width:8px;height:8px;border-radius:50%;background:#22C55E;display:inline-block;"></span> In Stock
            </span>
            &nbsp;
            <span style="display:inline-flex;align-items:center;gap:4px;">
              <span style="width:8px;height:8px;border-radius:50%;background:#F5D000;display:inline-block;"></span> Low Stock
            </span>
            &nbsp;
            <span style="display:inline-flex;align-items:center;gap:4px;">
              <span style="width:8px;height:8px;border-radius:50%;background:#DC2626;display:inline-block;"></span> Out of Stock
            </span>
          </span>
        </div>
      </div>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Item Name</th>
              <th>Category</th>
              <th>Qty</th>
              <th>Min Stock</th>
              <th>Status</th>
              <th>Assigned To</th>
              <th>Last Updated</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="inv-tbody">
            <!-- Rendered by JS -->
          </tbody>
        </table>
      </div>

      <div class="caution-strip"></div>

      <div class="pagination">
        <div class="pagination-info" id="pagination-info">Showing 1–20 of 20 items</div>
        <div class="pagination-btns">
          <button class="page-btn" disabled>
            <i data-lucide="chevron-left" style="width:13px;height:13px;"></i>
          </button>
          <button class="page-btn active">1</button>
          <button class="page-btn" disabled>
            <i data-lucide="chevron-right" style="width:13px;height:13px;"></i>
          </button>
        </div>
      </div>
    </div>

  </main>
</div>

<script>
  lucide.createIcons();

  // ── INVENTORY DATA ───────────────────────────────────
  const ITEMS = [
    {
      id: 1,
      name: 'V5 Smart Motor',
      sku: 'VEX-276-4840',
      category: 'Motors & Electronics',
      qty: 8,
      min: 4,
      status: 'In Stock',
      team: '839Z',
      updated: 'Feb 15, 2026',
    },
    {
      id: 2,
      name: 'High Strength Gears 84T',
      sku: 'VEX-276-2174',
      category: 'Structure',
      qty: 2,
      min: 6,
      status: 'Low Stock',
      team: '839Z',
      updated: 'Feb 12, 2026',
    },
    {
      id: 3,
      name: '4" Omni Wheels',
      sku: 'VEX-276-1772',
      category: 'Wheels & Drivetrain',
      qty: 1,
      min: 4,
      status: 'Low Stock',
      team: '839Y',
      updated: 'Feb 10, 2026',
    },
    {
      id: 4,
      name: 'V5 Robot Battery',
      sku: 'VEX-276-4811',
      category: 'Motors & Electronics',
      qty: 1,
      min: 2,
      status: 'Low Stock',
      team: 'Shared',
      updated: 'Feb 14, 2026',
    },
    {
      id: 5,
      name: 'V5 Smart Cables 300mm',
      sku: 'VEX-276-4852',
      category: 'Motors & Electronics',
      qty: 5,
      min: 8,
      status: 'Low Stock',
      team: '839Z',
      updated: 'Feb 11, 2026',
    },
    {
      id: 6,
      name: 'V5 Brain',
      sku: 'VEX-276-4810',
      category: 'Motors & Electronics',
      qty: 3,
      min: 2,
      status: 'In Stock',
      team: 'Shared',
      updated: 'Jan 30, 2026',
    },
    {
      id: 7,
      name: 'VEX Steel C-Channel 35-hole',
      sku: 'VEX-276-5429',
      category: 'Structure',
      qty: 24,
      min: 10,
      status: 'In Stock',
      team: '839X',
      updated: 'Feb 3, 2026',
    },
    {
      id: 8,
      name: 'Pneumatic Cylinder Double-Acting',
      sku: 'VEX-276-8600',
      category: 'Pneumatics',
      qty: 0,
      min: 2,
      status: 'Out of Stock',
      team: '839Y',
      updated: 'Jan 22, 2026',
    },
    {
      id: 9,
      name: 'VEX IQ Smart Motor',
      sku: 'VIQC-228-7014',
      category: 'Motors & Electronics',
      qty: 12,
      min: 6,
      status: 'In Stock',
      team: '839Z',
      updated: 'Feb 7, 2026',
    },
    {
      id: 10,
      name: 'Rubber Bands #32',
      sku: 'VEX-275-1143',
      category: 'Consumables',
      qty: 3,
      min: 5,
      status: 'Low Stock',
      team: 'Shared',
      updated: 'Feb 16, 2026',
    },
    {
      id: 11,
      name: '3.25" Traction Wheels',
      sku: 'VEX-276-1617',
      category: 'Wheels & Drivetrain',
      qty: 6,
      min: 4,
      status: 'In Stock',
      team: '839Z',
      updated: 'Feb 8, 2026',
    },
    {
      id: 12,
      name: 'Shaft Collars',
      sku: 'VEX-276-1910',
      category: 'Structure',
      qty: 47,
      min: 20,
      status: 'In Stock',
      team: 'Shared',
      updated: 'Jan 29, 2026',
    },
    {
      id: 13,
      name: 'Metal Screws M4x8',
      sku: 'VEX-275-1076',
      category: 'Consumables',
      qty: 200,
      min: 100,
      status: 'In Stock',
      team: 'Shared',
      updated: 'Jan 18, 2026',
    },
    {
      id: 14,
      name: 'Standoffs 0.5"',
      sku: 'VEX-276-1963',
      category: 'Structure',
      qty: 88,
      min: 40,
      status: 'In Stock',
      team: 'Shared',
      updated: 'Feb 1, 2026',
    },
    {
      id: 15,
      name: 'VEX AI Vision Sensor',
      sku: 'VEX-276-4860',
      category: 'Sensors',
      qty: 2,
      min: 1,
      status: 'In Stock',
      team: '839Y',
      updated: 'Feb 9, 2026',
    },
    {
      id: 16,
      name: 'Pneumatic Tank',
      sku: 'VEX-276-8610',
      category: 'Pneumatics',
      qty: 0,
      min: 1,
      status: 'Out of Stock',
      team: '839Y',
      updated: 'Jan 20, 2026',
    },
    {
      id: 17,
      name: 'GPS Sensor',
      sku: 'VEX-276-4859',
      category: 'Sensors',
      qty: 3,
      min: 2,
      status: 'In Stock',
      team: '839X',
      updated: 'Feb 6, 2026',
    },
    {
      id: 18,
      name: 'Cable Management Clips',
      sku: 'VEX-276-5001',
      category: 'Tools',
      qty: 15,
      min: 10,
      status: 'In Stock',
      team: 'Shared',
      updated: 'Feb 13, 2026',
    },
    {
      id: 19,
      name: 'Zip Ties',
      sku: 'GEN-ZT200',
      category: 'Consumables',
      qty: 1,
      min: 3,
      status: 'Low Stock',
      team: 'Shared',
      updated: 'Feb 17, 2026',
    },
    {
      id: 20,
      name: 'Anti-Static Foam',
      sku: 'GEN-ASF-STD',
      category: 'Tools',
      qty: 4,
      min: 2,
      status: 'In Stock',
      team: 'Shared',
      updated: 'Jan 25, 2026',
    },
  ];

  let filtered = [...ITEMS];

  // ── STATUS BADGE ─────────────────────────────────────
  function statusBadge(status) {
    if (status === 'In Stock') {
      return `<span class="badge badge-in-stock"><i data-lucide="check" style="width:10px;height:10px;"></i> In Stock</span>`;
    }
    if (status === 'Low Stock') {
      return `<span class="badge badge-low"><i data-lucide="triangle-alert" style="width:10px;height:10px;"></i> Low Stock</span>`;
    }
    if (status === 'Out of Stock') {
      return `<span class="badge badge-out"><i data-lucide="x" style="width:10px;height:10px;"></i> Out of Stock</span>`;
    }
    return '';
  }

  // ── TEAM CHIP ────────────────────────────────────────
  function teamChip(team) {
    if (team === 'Shared') {
      return `<span class="team-chip shared">Shared</span>`;
    }
    return `<span class="team-chip">${team}</span>`;
  }

  // ── QTY HTML ─────────────────────────────────────────
  function qtyHtml(item) {
    let cls = 'qty-cell';
    if (item.status === 'Out of Stock') cls += ' qty-zero';
    else if (item.status === 'Low Stock') cls += ' qty-low';
    const unit = item.name.includes('Rubber Bands') || item.name.includes('Zip Ties') ? '' : '';
    return `
      <div>
        <div class="${cls}">${item.qty}</div>
        <div class="min-qty">Min: ${item.min}</div>
      </div>`;
  }

  // ── REORDER BUTTON ───────────────────────────────────
  function reorderBtn(item) {
    if (item.status === 'In Stock') return '';
    return `<button class="reorder-btn" onclick="event.stopPropagation();fakeReorder('${item.name}')">
      <i data-lucide="refresh-cw" style="width:11px;height:11px;"></i> Reorder
    </button>`;
  }

  // ── RENDER TABLE ─────────────────────────────────────
  function renderTable() {
    const tbody = document.getElementById('inv-tbody');
    const count = document.getElementById('row-count');
    const pgInfo = document.getElementById('pagination-info');

    count.textContent = `${filtered.length} item${filtered.length !== 1 ? 's' : ''}`;
    pgInfo.textContent = `Showing 1–${filtered.length} of ${filtered.length} items`;

    tbody.innerHTML = filtered.map(item => {
      const isOos = item.status === 'Out of Stock';
      const rowClass = isOos ? 'oos-row' : '';
      return `<tr class="${rowClass}">
        <td>
          <div class="item-name">${item.name}</div>
          <div class="item-sku">${item.sku}</div>
        </td>
        <td><span class="cat-pill">${item.category}</span></td>
        <td>${qtyHtml(item)}</td>
        <td style="font-size:13px;color:var(--gray-1);font-weight:600;">${item.min}</td>
        <td>${statusBadge(item.status)}</td>
        <td>${teamChip(item.team)}</td>
        <td style="font-size:12px;color:var(--gray-1);">${item.updated}</td>
        <td>
          <div class="row-actions" style="position:relative;">
            ${reorderBtn(item)}
            <button class="more-btn" onclick="toggleRowDD(event,${item.id})">
              <i data-lucide="more-horizontal" style="width:13px;height:13px;"></i>
            </button>
            <div id="rdd-${item.id}" style="display:none;position:absolute;right:0;top:32px;background:var(--white);border:1px solid var(--gray-3);border-radius:var(--radius-sm);box-shadow:0 4px 12px rgba(0,0,0,.10);z-index:200;min-width:150px;overflow:hidden;">
              <div style="display:flex;align-items:center;gap:8px;padding:9px 12px;font-size:13px;color:var(--black-3);cursor:pointer;transition:background .1s;" onmouseover="this.style.background='var(--gray-4)'" onmouseout="this.style.background=''" onclick="editItemQty(${item.id})"><i data-lucide="pencil" style="width:13px;height:13px;"></i> Edit Qty</div>
              <div style="display:flex;align-items:center;gap:8px;padding:9px 12px;font-size:13px;color:var(--black-3);cursor:pointer;transition:background .1s;" onmouseover="this.style.background='var(--gray-4)'" onmouseout="this.style.background=''" onclick="window.location='inventory.html'"><i data-lucide="refresh-cw" style="width:13px;height:13px;"></i> Reorder</div>
              <div style="height:1px;background:var(--gray-3);margin:3px 0;"></div>
              <div style="display:flex;align-items:center;gap:8px;padding:9px 12px;font-size:13px;color:#DC2626;cursor:pointer;transition:background .1s;" onmouseover="this.style.background='#FEF2F2'" onmouseout="this.style.background=''" onclick="deleteItem(${item.id})"><i data-lucide="trash-2" style="width:13px;height:13px;"></i> Remove</div>
            </div>
          </div>
        </td>
      </tr>`;
    }).join('');

    lucide.createIcons();
  }

  // ── FILTERS ──────────────────────────────────────────
  function applyFilters() {
    const cat    = document.getElementById('filter-cat').value;
    const status = document.getElementById('filter-status').value;
    const team   = document.getElementById('filter-team').value;
    const search = document.getElementById('inv-search').value.toLowerCase().trim();

    filtered = ITEMS.filter(item => {
      if (cat    && item.category !== cat)    return false;
      if (status && item.status   !== status) return false;
      if (team   && item.team     !== team)   return false;
      if (search && !item.name.toLowerCase().includes(search) && !item.sku.toLowerCase().includes(search) && !item.category.toLowerCase().includes(search)) return false;
      return true;
    });

    renderTable();

    // active filter count badge
    let activeCount = 0;
    if (cat)    activeCount++;
    if (status) activeCount++;
    if (team)   activeCount++;
    if (search) activeCount++;
    const countWrap = document.getElementById('active-filter-count');
    const countBadge = document.getElementById('filter-count-badge');
    if (activeCount > 0) {
      countWrap.style.display = 'inline-flex';
      countBadge.textContent = activeCount;
    } else {
      countWrap.style.display = 'none';
    }
  }

  function clearFilters() {
    document.getElementById('filter-cat').value    = '';
    document.getElementById('filter-status').value = '';
    document.getElementById('filter-team').value   = '';
    document.getElementById('inv-search').value    = '';
    applyFilters();
  }

  // ── REORDER TOAST ────────────────────────────────────
  function fakeReorder(name) {
    const toast = document.createElement('div');
    toast.textContent = 'Sending reorder request for ' + name + '…';
    Object.assign(toast.style, {
      position: 'fixed',
      bottom: '28px',
      right: '28px',
      background: '#171717',
      color: '#fff',
      fontSize: '13px',
      fontWeight: '600',
      padding: '12px 20px',
      borderRadius: '8px',
      zIndex: '9999',
      boxShadow: '0 4px 12px rgba(0,0,0,.2)',
      fontFamily: 'Inter, sans-serif',
    });
    document.body.appendChild(toast);
    setTimeout(() => {
      toast.textContent = 'Reorder submitted for ' + name + '. Malhar Soni notified.';
      toast.style.background = '#15803D';
      setTimeout(() => toast.remove(), 2400);
    }, 1200);
  }

  // ── EXPORT CSV ─────────────────────────────────────
  function exportInventoryCSV() {
    const headers = ['Name','Category','Team','Qty','Status','Location','Unit Cost','Part#'];
    const rows = ITEMS.map(i => [
      i.name, i.category, i.team || 'General', i.qty, i.status,
      i.location || '', i.cost || '', i.part || ''
    ]);
    const csv = [headers, ...rows].map(r =>
      r.map(v => '"' + String(v || '').replace(/"/g, '""') + '"').join(',')
    ).join('\n');
    const blob = new Blob([csv], { type: 'text/csv' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'ctrc-inventory-' + new Date().toISOString().slice(0,10) + '.csv';
    a.click();
  }

  // ── ADD ITEM MODAL ─────────────────────────────────
  function openAddItem() {
    ['ai-name','ai-part','ai-qty','ai-cost','ai-location'].forEach(id => document.getElementById(id).value = '');
    document.getElementById('ai-category').value = 'Mechanical';
    document.getElementById('ai-team').value = '';
    document.getElementById('ai-backdrop').style.display = 'flex';
    lucide.createIcons();
    setTimeout(() => document.getElementById('ai-name').focus(), 50);
  }
  function closeAddItem(e) {
    if (e && e.target !== document.getElementById('ai-backdrop')) return;
    document.getElementById('ai-backdrop').style.display = 'none';
  }
  function submitAddItem() {
    const name = document.getElementById('ai-name').value.trim();
    if (!name) { document.getElementById('ai-name').style.borderColor='#EF4444'; document.getElementById('ai-name').focus(); return; }
    const newItem = {
      id: Date.now(), name,
      category: document.getElementById('ai-category').value,
      team: document.getElementById('ai-team').value || null,
      qty: parseInt(document.getElementById('ai-qty').value) || 1,
      status: 'OK',
      location: document.getElementById('ai-location').value,
      cost: document.getElementById('ai-cost').value,
      part: document.getElementById('ai-part').value,
      low: false
    };
    ITEMS.unshift(newItem);
    document.getElementById('ai-backdrop').style.display = 'none';
    renderTable();
    showInvToast(name + ' added to inventory');
  }

  // ── ROW DROPDOWN ────────────────────────────────────
  let openRowDD = null;
  function toggleRowDD(event, id) {
    event.stopPropagation();
    const dd = document.getElementById('rdd-' + id);
    if (!dd) return;
    const isOpen = dd.style.display === 'block';
    document.querySelectorAll('[id^="rdd-"]').forEach(d => d.style.display = 'none');
    dd.style.display = isOpen ? 'none' : 'block';
    openRowDD = isOpen ? null : id;
  }
  document.addEventListener('click', () => {
    document.querySelectorAll('[id^="rdd-"]').forEach(d => d.style.display = 'none');
    openRowDD = null;
  });
  function deleteItem(id) {
    const idx = ITEMS.findIndex(i => i.id === id);
    if (idx > -1) { const name = ITEMS[idx].name; ITEMS.splice(idx,1); renderTable(); showInvToast(name + ' removed'); }
  }
  function editItemQty(id) {
    const item = ITEMS.find(i => i.id === id);
    if (!item) return;
    const newQty = prompt('Update quantity for ' + item.name + ':', item.qty);
    if (newQty !== null && !isNaN(parseInt(newQty))) {
      item.qty = parseInt(newQty);
      item.status = item.qty <= (item.lowThreshold || 3) ? 'Low Stock' : 'OK';
      renderTable();
      showInvToast('Quantity updated to ' + item.qty);
    }
  }

  // ── TOAST ───────────────────────────────────────────
  let invToastTimer;
  function showInvToast(msg) {
    let t = document.getElementById('inv-toast');
    if (!t) return;
    t.style.display = 'flex';
    t.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#F5D000" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>&nbsp;' + msg;
    clearTimeout(invToastTimer);
    invToastTimer = setTimeout(() => { t.style.display = 'none'; }, 3000);
  }

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') document.getElementById('ai-backdrop').style.display = 'none';
  });

  // ── INIT ─────────────────────────────────────────────
  renderTable();

  /* ── NOTIFICATIONS ────────────────────────────────── */
  const NOTIFS = [
    { id:1, unread:true,  icon:'alert-circle',   color:'#EF4444', title:'Overdue Task', body:'Robot chassis CAD is 2 days overdue — Team 839Z', time:'2m ago' },
    { id:2, unread:true,  icon:'package',        color:'#F59E0B', title:'Low Inventory', body:'8020 Aluminum Extrusion is low stock (qty: 2)', time:'14m ago' },
    { id:3, unread:true,  icon:'users',          color:'#6366F1', title:'New Student', body:'Jordan Lee enrolled in Foundation Program', time:'1h ago' },
    { id:4, unread:false, icon:'trophy',         color:'#F5D000', title:'Competition Result', body:'Team 839Z placed 3rd at State Qualifier', time:'Yesterday' },
    { id:5, unread:false, icon:'check-circle-2', color:'#15803D', title:'Task Completed', body:'Electronics wiring completed by Sam Chen', time:'Yesterday' },
    { id:6, unread:false, icon:'calendar',       color:'#0EA5E9', title:'Upcoming Event', body:'Regional Championship in 12 days — Feb 28', time:'2d ago' },
  ];

  function renderNotifs() {
    const list = document.getElementById('notif-list');
    if (!list) return;
    list.innerHTML = NOTIFS.map(n => `
      <div style="display:flex;gap:12px;padding:12px 20px;cursor:pointer;background:${n.unread ? '#FAFAFA' : 'transparent'};border-left:3px solid ${n.unread ? 'var(--yellow)' : 'transparent'};transition:background .12s;" onmouseover="this.style.background='var(--gray-4)'" onmouseout="this.style.background='${n.unread ? '#FAFAFA' : 'transparent'}';" onclick="dismissNotif(${n.id},this)">
        <div style="width:34px;height:34px;border-radius:50%;background:${n.color}22;flex-shrink:0;display:flex;align-items:center;justify-content:center;">
          <i data-lucide="${n.icon}" style="width:15px;height:15px;color:${n.color};"></i>
        </div>
        <div style="flex:1;min-width:0;">
          <div style="font-size:13px;font-weight:${n.unread ? '700' : '500'};color:var(--black);margin-bottom:2px;">${n.title}</div>
          <div style="font-size:12px;color:var(--gray-1);line-height:1.4;margin-bottom:4px;">${n.body}</div>
          <div style="font-size:11px;color:var(--gray-2);">${n.time}</div>
        </div>
      </div>`).join('');
    lucide.createIcons();
  }

  function dismissNotif(id, el) {
    const idx = NOTIFS.findIndex(n => n.id === id);
    if (idx > -1) { NOTIFS[idx].unread = false; }
    el.style.borderLeftColor = 'transparent';
    el.style.background = 'transparent';
    el.querySelector('div[style*="font-weight"]').style.fontWeight = '500';
    updateBadge();
  }

  function markAllRead() {
    NOTIFS.forEach(n => n.unread = false);
    renderNotifs();
    updateBadge();
  }

  function updateBadge() {
    const dot = document.querySelector('.notif-dot');
    if (!dot) return;
    dot.style.display = NOTIFS.some(n => n.unread) ? '' : 'none';
  }

  function openNotifPanel() {
    const overlay = document.getElementById('notif-overlay');
    const panel   = document.getElementById('notif-panel');
    overlay.style.display = 'block';
    renderNotifs();
    setTimeout(() => { panel.style.transform = 'translateX(0)'; }, 10);
  }

  function closeNotifPanel(e) {
    if (e && e.target !== document.getElementById('notif-overlay')) return;
    const panel = document.getElementById('notif-panel');
    panel.style.transform = 'translateX(100%)';
    setTimeout(() => { document.getElementById('notif-overlay').style.display = 'none'; }, 230);
  }

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeNotifPanel(null);
  });
</script>

<!-- Notification Panel -->
<div id="notif-overlay" style="display:none;position:fixed;inset:0;z-index:600;" onclick="closeNotifPanel(event)">
  <div id="notif-panel" style="position:absolute;top:0;right:0;width:340px;height:100%;background:var(--white);box-shadow:-4px 0 24px rgba(0,0,0,.14);display:flex;flex-direction:column;transform:translateX(100%);transition:transform .22s ease;" onclick="event.stopPropagation()">
    <div style="display:flex;align-items:center;justify-content:space-between;padding:20px 20px 16px;border-bottom:1px solid var(--gray-3);">
      <span style="font-size:15px;font-weight:700;color:var(--black);">Notifications</span>
      <div style="display:flex;gap:8px;align-items:center;">
        <button onclick="markAllRead()" style="font-size:11px;font-weight:600;color:var(--gray-1);background:none;border:none;cursor:pointer;padding:4px 8px;border-radius:4px;" onmouseover="this.style.background='var(--gray-4)'" onmouseout="this.style.background='none'">Mark all read</button>
        <button onclick="closeNotifPanel(null)" style="background:none;border:none;cursor:pointer;color:var(--gray-2);font-size:20px;line-height:1;">&#x2715;</button>
      </div>
    </div>
    <div id="notif-list" style="flex:1;overflow-y:auto;padding:8px 0;"></div>
    <div style="padding:14px 20px;border-top:1px solid var(--gray-3);">
      <a href="#" style="font-size:12.5px;font-weight:600;color:var(--gray-1);text-decoration:none;">View all activity</a>
    </div>
  </div>
</div>

<!-- ADD ITEM MODAL -->
<div id="ai-backdrop" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:500;align-items:center;justify-content:center;" onclick="closeAddItem(event)">
  <div style="background:var(--white);border-radius:var(--radius);box-shadow:0 16px 48px rgba(0,0,0,.18);width:100%;max-width:460px;overflow:hidden;" onclick="event.stopPropagation()">
    <div style="padding:18px 20px;border-bottom:1px solid var(--gray-3);display:flex;align-items:center;justify-content:space-between;">
      <div style="font-size:15px;font-weight:800;">Add Inventory Item</div>
      <button onclick="closeAddItem()" style="background:none;border:none;cursor:pointer;color:var(--gray-1);padding:4px;"><i data-lucide="x" style="width:16px;height:16px;"></i></button>
    </div>
    <div style="padding:18px 20px;display:flex;flex-direction:column;gap:13px;">
      <div>
        <label style="font-size:11px;font-weight:700;color:var(--gray-1);text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:5px;">Item Name *</label>
        <input id="ai-name" type="text" placeholder="e.g. High Strength Gears" style="width:100%;border:1.5px solid var(--gray-3);border-radius:var(--radius-sm);padding:8px 12px;font-size:13px;font-family:'Inter',sans-serif;color:var(--black);outline:none;" onfocus="this.style.borderColor='var(--yellow)'" onblur="this.style.borderColor='var(--gray-3)'"/>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div>
          <label style="font-size:11px;font-weight:700;color:var(--gray-1);text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:5px;">Category</label>
          <select id="ai-category" style="width:100%;border:1.5px solid var(--gray-3);border-radius:var(--radius-sm);padding:8px 12px;font-size:13px;font-family:'Inter',sans-serif;color:var(--black);outline:none;background:var(--white);">
            <option>Mechanical</option><option>Electronics</option><option>Structural</option><option>Software</option><option>Consumables</option><option>Safety</option>
          </select>
        </div>
        <div>
          <label style="font-size:11px;font-weight:700;color:var(--gray-1);text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:5px;">Team</label>
          <select id="ai-team" style="width:100%;border:1.5px solid var(--gray-3);border-radius:var(--radius-sm);padding:8px 12px;font-size:13px;font-family:'Inter',sans-serif;color:var(--black);outline:none;background:var(--white);">
            <option value="">General / All Teams</option><option>839Z</option><option>839Y</option><option>839X</option><option>839Z</option>
          </select>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;">
        <div>
          <label style="font-size:11px;font-weight:700;color:var(--gray-1);text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:5px;">Qty</label>
          <input id="ai-qty" type="number" min="0" value="1" style="width:100%;border:1.5px solid var(--gray-3);border-radius:var(--radius-sm);padding:8px 12px;font-size:13px;font-family:'Inter',sans-serif;color:var(--black);outline:none;" onfocus="this.style.borderColor='var(--yellow)'" onblur="this.style.borderColor='var(--gray-3)'"/>
        </div>
        <div>
          <label style="font-size:11px;font-weight:700;color:var(--gray-1);text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:5px;">Unit Cost</label>
          <input id="ai-cost" type="text" placeholder="$0.00" style="width:100%;border:1.5px solid var(--gray-3);border-radius:var(--radius-sm);padding:8px 12px;font-size:13px;font-family:'Inter',sans-serif;color:var(--black);outline:none;" onfocus="this.style.borderColor='var(--yellow)'" onblur="this.style.borderColor='var(--gray-3)'"/>
        </div>
        <div>
          <label style="font-size:11px;font-weight:700;color:var(--gray-1);text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:5px;">Part #</label>
          <input id="ai-part" type="text" placeholder="VEX-####" style="width:100%;border:1.5px solid var(--gray-3);border-radius:var(--radius-sm);padding:8px 12px;font-size:13px;font-family:'Inter',sans-serif;color:var(--black);outline:none;" onfocus="this.style.borderColor='var(--yellow)'" onblur="this.style.borderColor='var(--gray-3)'"/>
        </div>
      </div>
      <div>
        <label style="font-size:11px;font-weight:700;color:var(--gray-1);text-transform:uppercase;letter-spacing:.06em;display:block;margin-bottom:5px;">Storage Location</label>
        <input id="ai-location" type="text" placeholder="e.g. Cabinet B, Shelf 2" style="width:100%;border:1.5px solid var(--gray-3);border-radius:var(--radius-sm);padding:8px 12px;font-size:13px;font-family:'Inter',sans-serif;color:var(--black);outline:none;" onfocus="this.style.borderColor='var(--yellow)'" onblur="this.style.borderColor='var(--gray-3)'"/>
      </div>
    </div>
    <div style="padding:14px 20px;border-top:1px solid var(--gray-3);display:flex;gap:8px;justify-content:flex-end;">
      <button class="btn btn-outline" onclick="closeAddItem()">Cancel</button>
      <button class="btn btn-yellow" onclick="submitAddItem()"><i data-lucide="plus" style="width:13px;height:13px;"></i> Add Item</button>
    </div>
  </div>
</div>

<div id="inv-toast" style="display:none;position:fixed;bottom:24px;right:24px;background:var(--black);color:var(--white);padding:12px 18px;border-radius:var(--radius-sm);font-size:13px;font-weight:600;z-index:600;box-shadow:0 4px 16px rgba(0,0,0,.2);align-items:center;gap:8px;"></div>
</body>
</html>
