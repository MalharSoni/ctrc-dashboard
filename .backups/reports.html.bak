            <div class="export-row">
              <div class="export-icon-wrap">
                <i data-lucide="file-text" style="width:14px;height:14px;"></i>
              </div>
              <div>
                <div class="export-name">Competition Results.pdf</div>
                <div class="export-date">Jan 28, 2026 &nbsp;·&nbsp; 640 KB</div>
              </div>
              <button class="export-dl" onclick="fakeDownload('Competition Results')">
