    </div>

    <!-- ─── PANEL: SEASON SUMMARY ─── -->
    <div class="tab-panel active" id="panel-season">

      <!-- STAT ROW -->
      <div class="stat-grid-4">
        <div class="stat-card accent-yellow">
          <div class="stat-icon yellow-bg"><i data-lucide="calendar-days" style="width:15px;height:15px;"></i></div>
