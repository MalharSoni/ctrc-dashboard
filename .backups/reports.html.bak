        </div>
        <div class="coming-soon-title">Attendance Report Coming Soon</div>
        <div class="coming-soon-desc">Detailed per-student attendance tracking with trends, excused absences, and weekly breakdowns will appear here.</div>
        <button class="btn btn-yellow" onclick="notifyMe(this)">
          <i data-lucide="bell" style="width:13px;height:13px;"></i>
          Notify me when ready
        </button>
      </div>
    </div>

    <!-- ─── PANEL: TEAM PERFORMANCE ─── -->
    <div class="tab-panel" id="panel-teams">
      <div class="coming-soon">
        <div class="coming-soon-icon">
          <img src="icon-black.png" style="width:28px;opacity:.5;" alt="CTRC" />
        </div>
        <div class="coming-soon-title">Team Performance Report Coming Soon</div>
        <div class="coming-soon-desc">Head-to-head match analysis, driver skills scores, autonomous performance, and OPR charts will appear here.</div>
        <button class="btn btn-yellow" onclick="notifyMe(this)">
          <i data-lucide="bell" style="width:13px;height:13px;"></i>
          Notify me when ready
        </button>
      </div>
    </div>

    <!-- ─── PANEL: STUDENT PROGRESS ─── -->
    <div class="tab-panel" id="panel-students">
      <div class="coming-soon">
        <div class="coming-soon-icon">
          <img src="icon-black.png" style="width:28px;opacity:.5;" alt="CTRC" />
        </div>
        <div class="coming-soon-title">Student Progress Report Coming Soon</div>
        <div class="coming-soon-desc">Individual skill growth, badge milestones, task completion rates, and Engineering Notebook scores will appear here.</div>
        <button class="btn btn-yellow" onclick="notifyMe(this)">
          <i data-lucide="bell" style="width:13px;height:13px;"></i>
          Notify me when ready
        </button>
      </div>
    </div>

    <!-- ─── PANEL: COMPETITION RESULTS ─── -->
    <div class="tab-panel" id="panel-competition">
      <div class="coming-soon">
        <div class="coming-soon-icon">
          <img src="icon-black.png" style="width:28px;opacity:.5;" alt="CTRC" />
        </div>
        <div class="coming-soon-title">Competition Results Coming Soon</div>
        <div class="coming-soon-desc">Full match logs, alliance selections, awards won, and qualification rankings across all events will appear here.</div>
        <button class="btn btn-yellow" onclick="notifyMe(this)">
          <i data-lucide="bell" style="width:13px;height:13px;"></i>
          Notify me when ready
        </button>
      </div>
    </div>

  </main>
</div>

<script>
  lucide.createIcons();

  // ── TAB SWITCHING ────────────────────────────────────
  const TAB_MAP = {
    'season':      'panel-season',
    'attendance':  'panel-attendance',
    'teams':       'panel-teams',
    'students':    'panel-students',
    'competition': 'panel-competition',
  };

  function switchTab(name) {
    // update tab styles
    Object.keys(TAB_MAP).forEach(k => {
      document.getElementById('tab-' + k).classList.toggle('active', k === name);
    });
    // show/hide panels
    Object.values(TAB_MAP).forEach(panelId => {
      document.getElementById(panelId).classList.remove('active');
    });
    document.getElementById(TAB_MAP[name]).classList.add('active');
    lucide.createIcons();
  }

  // ── TOAST ────────────────────────────────────────────
  let rpToastTimer;
  function showRPToast(msg) {
    const t = document.getElementById('rp-toast');
    t.style.display = 'flex';
    t.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#F5D000" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>&nbsp;' + msg;
    clearTimeout(rpToastTimer);
    rpToastTimer = setTimeout(() => { t.style.display = 'none'; }, 3400);
  }

  // ── REAL CSV DOWNLOAD ─────────────────────────────────
  function downloadCSV(filename, rows) {
    const csv = rows.map(r => r.map(v => '"' + String(v == null ? '' : v).replace(/"/g, '""') + '"').join(',')).join('\n');
    const blob = new Blob([csv], { type: 'text/csv' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = filename;
    a.click();
    URL.revokeObjectURL(a.href);
  }

  // Season Summary CSV
  function seasonSummaryCSV() {
    const rows = [
      ['Metric', 'Value', 'Season'],
      ['Total Students', 47, '2024-25'],
      ['Active Teams', 5, '2024-25'],
      ['Competitions Attended', 8, '2024-25'],
      ['Awards Won', 12, '2024-25'],
      ['Average Attendance %', '84%', '2024-25'],
      ['Tasks Completed', 134, '2024-25'],
      ['Badges Issued', 89, '2024-25'],
    ];
    downloadCSV('ctrc-season-summary-' + new Date().toISOString().slice(0,10) + '.csv', rows);
    showRPToast('Season Summary CSV downloaded');
  }

  // Attendance CSV
  function attendanceCSV() {
    const rows = [
      ['Student Name', 'Team', 'Grade', 'Sessions Attended', 'Total Sessions', 'Attendance %', 'Last Seen'],
      ['Alex Rivera', '839Z', '11', 28, 32, '87%', '2025-01-10'],
      ['Jordan Lee', '839Z', '10', 30, 32, '93%', '2025-01-10'],
      ['Sam Chen', '839Y', '12', 25, 32, '78%', '2025-01-08'],
      ['Morgan Davis', '839Y', '9', 32, 32, '100%', '2025-01-10'],
      ['Taylor Kim', '839X', '11', 20, 32, '62%', '2024-12-20'],
      ['Riley Park', '839X', '10', 27, 32, '84%', '2025-01-09'],
    ];
    downloadCSV('ctrc-attendance-' + new Date().toISOString().slice(0,10) + '.csv', rows);
    showRPToast('Attendance Report CSV downloaded');
  }

  // Student Progress CSV
  function studentProgressCSV() {
    const rows = [
      ['Student Name', 'Team', 'Grade', 'Skill Level', 'Badges Earned', 'Tasks Assigned', 'Tasks Completed', 'Completion %'],
      ['Alex Rivera', '839Z', '11', 'Advanced', 7, 18, 16, '88%'],
      ['Jordan Lee', '839Z', '10', 'Intermediate', 5, 14, 12, '85%'],
      ['Sam Chen', '839Y', '12', 'Expert', 10, 22, 21, '95%'],
      ['Morgan Davis', '839Y', '9', 'Beginner', 2, 8, 6, '75%'],
      ['Taylor Kim', '839X', '11', 'Intermediate', 4, 12, 9, '75%'],
      ['Riley Park', '839X', '10', 'Beginner', 3, 10, 8, '80%'],
    ];
    downloadCSV('ctrc-student-progress-' + new Date().toISOString().slice(0,10) + '.csv', rows);
    showRPToast('Student Progress CSV downloaded');
  }

  // Competition Results CSV
  function competitionCSV() {
    const rows = [
      ['Event', 'Date', 'Team', 'Qualification Rank', 'W-L-T', 'Alliance', 'Result', 'Awards'],
      ['Qualifier #1', '2024-10-12', '839Z', 3, '8-2-0', 'Alliance 2 Captain', 'Finalist', 'Excellence Award'],
      ['Qualifier #1', '2024-10-12', '839Y', 7, '6-4-0', 'Alliance 3 Partner', 'Quarterfinalist', 'Design Award'],
      ['Qualifier #2', '2024-11-09', '839Z', 1, '9-1-0', 'Alliance 1 Captain', 'Champion', 'Tournament Champion'],
      ['State Championship', '2024-12-14', '839Z', 12, '5-5-0', 'Alliance 5 Partner', 'Quarterfinalist', ''],
    ];
    downloadCSV('ctrc-competition-results-' + new Date().toISOString().slice(0,10) + '.csv', rows);
    showRPToast('Competition Results CSV downloaded');
  }

  // fakeDownload now routes to real CSV by report name
  function fakeDownload(name) {
    if (name === 'Season Summary') return seasonSummaryCSV();
    if (name === 'Attendance Report') return attendanceCSV();
    if (name === 'Student Progress Report' || name === 'Student Progress') return studentProgressCSV();
    if (name === 'Competition Results') return competitionCSV();
    // Foundation Progress — generic
    const rows = [['Student','Grade','Sessions','Skill Level','Status'],['Alex R.','9','12','Beginner','On Track'],['Jordan L.','9','10','Beginner','At Risk']];
    downloadCSV('ctrc-' + name.toLowerCase().replace(/ /g,'-') + '-' + new Date().toISOString().slice(0,10) + '.csv', rows);
    showRPToast(name + ' CSV downloaded');
  }

  // Export All — download each CSV in sequence
  function exportAll() {
    showRPToast('Exporting all reports…');
    setTimeout(() => seasonSummaryCSV(), 200);
    setTimeout(() => attendanceCSV(), 600);
    setTimeout(() => studentProgressCSV(), 1000);
    setTimeout(() => competitionCSV(), 1400);
    setTimeout(() => showRPToast('All 4 reports exported'), 1800);
  }

  // Notify me — toggle subscribed state
  function notifyMe(btn) {
    const already = btn.dataset.subscribed === '1';
    if (already) {
      btn.dataset.subscribed = '';
      btn.innerHTML = '<i data-lucide="bell" style="width:13px;height:13px;"></i> Notify me when ready';
      btn.style.opacity = '';
      lucide.createIcons();
      showRPToast('Notification removed');
    } else {
      btn.dataset.subscribed = '1';
      btn.innerHTML = '<i data-lucide="bell-ring" style="width:13px;height:13px;"></i> Subscribed';
      btn.style.background = 'var(--yellow-dim)';
      lucide.createIcons();
      showRPToast('You\'ll be notified when this report is ready');
    }
  }

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') document.getElementById('rp-toast').style.display = 'none';
  });

  /* ── NOTIFICATIONS ────────────────────────────────── */
  const NOTIFS = [
    { id:1, unread:true,  icon:'alert-circle',   color:'#EF4444', title:'Overdue Task', body:'Robot chassis CAD is 2 days overdue — Team 839Z', time:'2m ago' },
    { id:2, unread:true,  icon:'package',        color:'#F59E0B', title:'Low Inventory', body:'8020 Aluminum Extrusion is low stock (qty: 2)', time:'14m ago' },
    { id:3, unread:true,  icon:'users',          color:'#6366F1', title:'New Student', body:'Jordan Lee enrolled in Foundation Program', time:'1h ago' },
    { id:4, unread:false, icon:'trophy',         color:'#F5D000', title:'Competition Result', body:'Team 839Z placed 3rd at State Qualifier', time:'Yesterday' },
    { id:5, unread:false, icon:'check-circle-2', color:'#15803D', title:'Task Completed', body:'Electronics wiring completed by Sam Chen', time:'Yesterday' },
    { id:6, unread:false, icon:'calendar',       color:'#0EA5E9', title:'Upcoming Event', body:'Regional Championship in 12 days — Feb 28', time:'2d ago' },
  ];

  function renderNotifs() {
    const list = document.getElementById('notif-list');
    if (!list) return;
    list.innerHTML = NOTIFS.map(n => `
      <div style="display:flex;gap:12px;padding:12px 20px;cursor:pointer;background:${n.unread ? '#FAFAFA' : 'transparent'};border-left:3px solid ${n.unread ? 'var(--yellow)' : 'transparent'};transition:background .12s;" onmouseover="this.style.background='var(--gray-4)'" onmouseout="this.style.background='${n.unread ? '#FAFAFA' : 'transparent'}';" onclick="dismissNotif(${n.id},this)">
        <div style="width:34px;height:34px;border-radius:50%;background:${n.color}22;flex-shrink:0;display:flex;align-items:center;justify-content:center;">
          <i data-lucide="${n.icon}" style="width:15px;height:15px;color:${n.color};"></i>
        </div>
        <div style="flex:1;min-width:0;">
          <div style="font-size:13px;font-weight:${n.unread ? '700' : '500'};color:var(--black);margin-bottom:2px;">${n.title}</div>
          <div style="font-size:12px;color:var(--gray-1);line-height:1.4;margin-bottom:4px;">${n.body}</div>
          <div style="font-size:11px;color:var(--gray-2);">${n.time}</div>
        </div>
      </div>`).join('');
    lucide.createIcons();
  }

  function dismissNotif(id, el) {
    const idx = NOTIFS.findIndex(n => n.id === id);
    if (idx > -1) { NOTIFS[idx].unread = false; }
    el.style.borderLeftColor = 'transparent';
    el.style.background = 'transparent';
    el.querySelector('div[style*="font-weight"]').style.fontWeight = '500';
    updateBadge();
  }

  function markAllRead() {
    NOTIFS.forEach(n => n.unread = false);
    renderNotifs();
    updateBadge();
  }

  function updateBadge() {
    const dot = document.querySelector('.notif-dot');
    if (!dot) return;
    dot.style.display = NOTIFS.some(n => n.unread) ? '' : 'none';
  }

  function openNotifPanel() {
    const overlay = document.getElementById('notif-overlay');
    const panel   = document.getElementById('notif-panel');
    overlay.style.display = 'block';
    renderNotifs();
    setTimeout(() => { panel.style.transform = 'translateX(0)'; }, 10);
  }

  function closeNotifPanel(e) {
    if (e && e.target !== document.getElementById('notif-overlay')) return;
    const panel = document.getElementById('notif-panel');
    panel.style.transform = 'translateX(100%)';
    setTimeout(() => { document.getElementById('notif-overlay').style.display = 'none'; }, 230);
  }

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeNotifPanel(null);
  });
</script>

<!-- Toast -->
<div id="rp-toast" style="display:none;position:fixed;bottom:24px;right:24px;background:var(--black);color:var(--white);font-size:13px;font-weight:600;padding:12px 18px;border-radius:var(--radius-sm);z-index:9999;align-items:center;gap:8px;box-shadow:0 4px 16px rgba(0,0,0,.22);font-family:'Inter',sans-serif;"></div>

<!-- Notification Panel -->
<div id="notif-overlay" style="display:none;position:fixed;inset:0;z-index:600;" onclick="closeNotifPanel(event)">
  <div id="notif-panel" style="position:absolute;top:0;right:0;width:340px;height:100%;background:var(--white);box-shadow:-4px 0 24px rgba(0,0,0,.14);display:flex;flex-direction:column;transform:translateX(100%);transition:transform .22s ease;" onclick="event.stopPropagation()">
    <div style="display:flex;align-items:center;justify-content:space-between;padding:20px 20px 16px;border-bottom:1px solid var(--gray-3);">
      <span style="font-size:15px;font-weight:700;color:var(--black);">Notifications</span>
      <div style="display:flex;gap:8px;align-items:center;">
        <button onclick="markAllRead()" style="font-size:11px;font-weight:600;color:var(--gray-1);background:none;border:none;cursor:pointer;padding:4px 8px;border-radius:4px;" onmouseover="this.style.background='var(--gray-4)'" onmouseout="this.style.background='none'">Mark all read</button>
        <button onclick="closeNotifPanel(null)" style="background:none;border:none;cursor:pointer;color:var(--gray-2);font-size:20px;line-height:1;">&#x2715;</button>
      </div>
    </div>
    <div id="notif-list" style="flex:1;overflow-y:auto;padding:8px 0;"></div>
    <div style="padding:14px 20px;border-top:1px solid var(--gray-3);">
      <a href="#" style="font-size:12.5px;font-weight:600;color:var(--gray-1);text-decoration:none;">View all activity</a>
    </div>
  </div>
</div>

</body>
</html>
