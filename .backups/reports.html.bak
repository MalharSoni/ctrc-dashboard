<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Reports — CTRC Club Manager</title>

  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <style>
    @font-face { font-family: 'Inter'; font-style: normal; font-weight: 400; font-display: block; src: url('fonts/inter-400.woff2') format('woff2'); }
    @font-face { font-family: 'Inter'; font-style: normal; font-weight: 500; font-display: block; src: url('fonts/inter-500.woff2') format('woff2'); }
    @font-face { font-family: 'Inter'; font-style: normal; font-weight: 600; font-display: block; src: url('fonts/inter-600.woff2') format('woff2'); }
    @font-face { font-family: 'Inter'; font-style: normal; font-weight: 700; font-display: block; src: url('fonts/inter-700.woff2') format('woff2'); }
    @font-face { font-family: 'Inter'; font-style: normal; font-weight: 800; font-display: block; src: url('fonts/inter-800.woff2') format('woff2'); }
    @font-face { font-family: 'Inter'; font-style: normal; font-weight: 900; font-display: block; src: url('fonts/inter-900.woff2') format('woff2'); }
  </style>

  <style>
    /* ── DESIGN TOKENS ─────────────────────────────── */
    :root {
      --yellow:      #F5D000;
      --yellow-dim:  #C8AA00;
      --yellow-bg:   #FFFBDC;
      --black:       #171717;
      --black-2:     #262626;
      --black-3:     #404040;
      --gray-1:      #737373;
      --gray-2:      #A3A3A3;
      --gray-3:      #D4D4D4;
      --gray-4:      #F5F5F5;
      --white:       #FFFFFF;
      --sidebar-w:   240px;
      --radius:      10px;
      --radius-sm:   6px;
      --shadow:      0 1px 3px rgba(0,0,0,.08), 0 1px 2px rgba(0,0,0,.05);
      --shadow-md:   0 4px 12px rgba(0,0,0,.10);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      background: var(--gray-4);
      color: var(--black);
      min-height: 100vh;
      display: flex;
    }

    /* ── SIDEBAR ───────────────────────────────────── */
    .sidebar {
      width: var(--sidebar-w);
      background: var(--black);
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0; left: 0; bottom: 0;
      z-index: 100;
    }
    .sidebar-logo { padding: 20px 18px 16px; border-bottom: 1px solid var(--black-3); }
    .sidebar-logo img { width: 140px; display: block; }
    .sidebar-logo-sub { font-size: 10px; color: var(--gray-2); letter-spacing: .08em; text-transform: uppercase; margin-top: 6px; }
    .sidebar-nav { flex: 1; padding: 12px 10px; display: flex; flex-direction: column; gap: 2px; }
    .nav-section-label { font-size: 10px; font-weight: 600; color: var(--gray-1); letter-spacing: .1em; text-transform: uppercase; padding: 10px 8px 4px; }
    .nav-item {
      display: flex; align-items: center; gap: 10px;
      padding: 8px 10px; border-radius: var(--radius-sm);
      color: var(--gray-2); font-size: 13.5px; font-weight: 500;
      cursor: pointer; transition: background .15s, color .15s;
      text-decoration: none; position: relative;
    }
    .nav-item:hover { background: var(--black-2); color: var(--white); }
    .nav-item.active { background: var(--yellow); color: var(--black); font-weight: 700; }
    .nav-item.active i { color: var(--black); }
    .nav-item i { width: 16px; height: 16px; }
    .nav-badge {
      margin-left: auto; background: var(--yellow); color: var(--black);
      font-size: 10px; font-weight: 700; padding: 1px 6px; border-radius: 99px;
    }
    .nav-item.active .nav-badge { background: var(--black); color: var(--yellow); }
    .sidebar-footer { padding: 14px 14px; border-top: 1px solid var(--black-3); }
    .sidebar-user { display: flex; align-items: center; gap: 10px; cursor: pointer; }
    .sidebar-avatar { width: 34px; height: 34px; border-radius: 50%; background: var(--yellow); display: flex; align-items: center; justify-content: center; overflow: hidden; flex-shrink: 0; }
    .sidebar-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .sidebar-user-name { font-size: 13px; font-weight: 600; color: var(--white); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .sidebar-user-role { font-size: 11px; color: var(--gray-2); }

    /* ── MAIN ──────────────────────────────────────── */
    .main { margin-left: var(--sidebar-w); flex: 1; min-width: 0; overflow-x: hidden; display: flex; flex-direction: column; min-height: 100vh; }

    /* ── TOPBAR ────────────────────────────────────── */
    .topbar {
      background: var(--white); border-bottom: 1px solid var(--gray-3);
      padding: 0 28px; height: 56px; display: flex; align-items: center;
      gap: 12px; position: sticky; top: 0; z-index: 50;
    }
    .breadcrumb { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--gray-1); }
    .breadcrumb a { color: var(--gray-1); text-decoration: none; }
    .breadcrumb a:hover { color: var(--black); }
    .breadcrumb-sep { color: var(--gray-3); }
    .breadcrumb-current { color: var(--black); font-weight: 600; }
    .search-wrap {
      display: flex; align-items: center; gap: 8px;
      background: var(--gray-4); border: 1px solid var(--gray-3);
      border-radius: var(--radius-sm); padding: 6px 12px;
      flex: 1; max-width: 380px; cursor: text;
    }
    .search-wrap input { border: none; background: transparent; font-size: 13px; color: var(--black); outline: none; width: 100%; }
    .search-wrap input::placeholder { color: var(--gray-2); }
    .search-kbd { font-size: 10px; color: var(--gray-2); background: var(--white); border: 1px solid var(--gray-3); border-radius: 4px; padding: 1px 5px; white-space: nowrap; }
    .topbar-right { margin-left: auto; display: flex; align-items: center; gap: 8px; }
    .btn { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 600; padding: 7px 14px; border-radius: var(--radius-sm); border: none; cursor: pointer; transition: opacity .15s, transform .1s; font-family: 'Inter', sans-serif; }
    .btn:active { transform: scale(.97); }
    .btn-yellow { background: var(--yellow); color: var(--black); }
    .btn-yellow:hover { opacity: .88; }
    .btn-outline { background: transparent; border: 1.5px solid var(--gray-3); color: var(--black-3); }
    .btn-outline:hover { border-color: var(--gray-2); }
    .btn-sm { font-size: 12px; padding: 5px 10px; }
    .icon-btn { width: 34px; height: 34px; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; border: 1.5px solid var(--gray-3); background: var(--white); cursor: pointer; color: var(--gray-1); transition: all .15s; position: relative; }
    .icon-btn:hover { border-color: var(--gray-2); color: var(--black); }
    .notif-dot { position: absolute; top: 5px; right: 5px; width: 7px; height: 7px; background: var(--yellow); border-radius: 50%; border: 1.5px solid var(--white); }

    /* ── CONTENT ───────────────────────────────────── */
    .content { padding: 28px; display: flex; flex-direction: column; gap: 24px; }
    .page-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
    .page-title { font-size: 22px; font-weight: 800; color: var(--black); letter-spacing: -.02em; }
    .page-subtitle { font-size: 13px; color: var(--gray-1); margin-top: 2px; }

    /* ── TABS ──────────────────────────────────────── */
    .tabs-wrap {
      display: flex;
      align-items: center;
      gap: 0;
      border-bottom: 2px solid var(--gray-3);
    }
    .tab-item {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 10px 18px;
      font-size: 13px;
      font-weight: 600;
      color: var(--gray-1);
      cursor: pointer;
      border-bottom: 2px solid transparent;
      margin-bottom: -2px;
      transition: color .15s, border-color .15s;
      white-space: nowrap;
      user-select: none;
    }
    .tab-item:hover { color: var(--black); }
    .tab-item.active { color: var(--black); border-bottom-color: var(--yellow); }

    /* ── STAT CARDS ────────────────────────────────── */
    .stat-grid-4 {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
    }
    .stat-card {
      background: var(--white);
      border: 1px solid var(--gray-3);
      border-radius: var(--radius);
      padding: 16px 18px;
      display: flex;
      flex-direction: column;
      gap: 6px;
      box-shadow: var(--shadow);
      position: relative;
      overflow: hidden;
    }
    .stat-card.accent-yellow { border-top: 3px solid var(--yellow); }
    .stat-card.accent-green  { border-top: 3px solid #22C55E; }
    .stat-label { font-size: 10.5px; font-weight: 700; color: var(--gray-1); letter-spacing: .07em; text-transform: uppercase; }
    .stat-value { font-size: 28px; font-weight: 900; color: var(--black); letter-spacing: -.03em; line-height: 1; }
    .stat-meta { font-size: 11.5px; color: var(--gray-2); display: flex; align-items: center; gap: 4px; }
    .stat-icon { position: absolute; top: 14px; right: 14px; width: 30px; height: 30px; background: var(--gray-4); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; color: var(--gray-2); }
    .stat-icon.yellow-bg { background: var(--yellow-bg); color: var(--yellow-dim); }
    .stat-icon.green-bg  { background: #F0FDF4; color: #15803D; }

    /* ── CARDS ─────────────────────────────────────── */
    .card {
      background: var(--white);
      border: 1px solid var(--gray-3);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow: hidden;
    }
    .card-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 16px 20px 14px; border-bottom: 1px solid var(--gray-3);
    }
    .card-title { font-size: 14px; font-weight: 700; color: var(--black); }
    .card-subtitle { font-size: 12px; color: var(--gray-1); margin-top: 2px; }
    .card-link { font-size: 12px; color: var(--gray-1); font-weight: 500; cursor: pointer; display: flex; align-items: center; gap: 3px; text-decoration: none; }
    .card-link:hover { color: var(--black); }

    /* ── TWO-COL ───────────────────────────────────── */
    .two-col {
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 20px;
      align-items: start;
    }
    .left-col { display: flex; flex-direction: column; gap: 20px; }
    .right-col { display: flex; flex-direction: column; gap: 16px; }

    /* ── CSS BAR CHART ─────────────────────────────── */
    .chart-area {
      padding: 20px 20px 0;
    }
    .chart-bars {
      display: flex;
      align-items: flex-end;
      gap: 10px;
      height: 160px;
    }
    .chart-col {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      flex: 1;
    }
    .bar-track {
      width: 100%;
      height: 140px;
      background: var(--gray-4);
      border-radius: 4px 4px 0 0;
      display: flex;
      align-items: flex-end;
      overflow: hidden;
      position: relative;
    }
    .bar-fill {
      width: 100%;
      background: var(--yellow);
      border-radius: 4px 4px 0 0;
      transition: height .4s ease;
      position: relative;
    }
    .bar-fill:hover { opacity: .8; }
    .bar-value {
      position: absolute;
      top: -20px;
      left: 50%;
      transform: translateX(-50%);
      font-size: 10px;
      font-weight: 700;
      color: var(--black-3);
      white-space: nowrap;
    }
    .bar-label {
      font-size: 11px;
      font-weight: 500;
      color: var(--gray-1);
      text-align: center;
      white-space: nowrap;
    }
    .chart-legend {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 14px 20px 16px;
      border-top: 1px solid var(--gray-3);
      margin-top: 6px;
    }
    .legend-dot {
      width: 10px; height: 10px;
      border-radius: 2px;
    }
    .legend-item { display: flex; align-items: center; gap: 5px; font-size: 12px; color: var(--gray-1); }
    .chart-y-labels {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      height: 140px;
      padding-right: 8px;
      flex-shrink: 0;
    }
    .chart-y-label {
      font-size: 10px;
      color: var(--gray-2);
      line-height: 1;
    }
    .chart-inner {
      display: flex;
      align-items: flex-end;
      gap: 6px;
      width: 100%;
    }

    /* ── TABLE ─────────────────────────────────────── */
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; }
    thead th {
      font-size: 11px; font-weight: 700; color: var(--gray-1);
      letter-spacing: .06em; text-transform: uppercase;
      text-align: left; padding: 10px 20px;
      border-bottom: 1px solid var(--gray-3);
      background: var(--gray-4);
      white-space: nowrap;
    }
    tbody tr { border-bottom: 1px solid var(--gray-3); transition: background .1s; }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: var(--yellow-bg); }
    td { padding: 12px 20px; font-size: 13px; color: var(--black-3); vertical-align: middle; }
    .team-name { font-weight: 700; color: var(--black); }

    /* ── BADGES ────────────────────────────────────── */
    .badge {
      display: inline-flex; align-items: center; gap: 4px;
      font-size: 10.5px; font-weight: 700;
      padding: 2px 8px; border-radius: 4px;
      letter-spacing: .03em; text-transform: uppercase;
    }
    .badge-green  { background: #F0FDF4; color: #15803D; }
    .badge-red    { background: #FEF2F2; color: #DC2626; }
    .badge-yellow { background: var(--yellow-bg); color: #92700A; }
    .badge-gray   { background: var(--gray-3); color: var(--black-3); }
    .badge-black  { background: var(--black); color: var(--white); }
    .badge-purple { background: #F5F3FF; color: #6D28D9; }

    /* ── WIN RATE BAR ──────────────────────────────── */
    .win-rate-cell { display: flex; align-items: center; gap: 8px; min-width: 120px; }
    .win-pct { font-size: 13px; font-weight: 700; min-width: 36px; }
    .win-bar { flex: 1; height: 5px; background: var(--gray-3); border-radius: 99px; overflow: hidden; }
    .win-fill { height: 100%; background: #22C55E; border-radius: 99px; }

    /* ── QUICK REPORTS ─────────────────────────────── */
    .report-row {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 20px;
      border-bottom: 1px solid var(--gray-3);
      transition: background .1s;
    }
    .report-row:last-child { border-bottom: none; }
    .report-row:hover { background: var(--gray-4); }
    .report-icon {
      width: 36px; height: 36px;
      background: var(--yellow-bg);
      border-radius: var(--radius-sm);
      display: flex; align-items: center; justify-content: center;
      color: var(--yellow-dim);
      flex-shrink: 0;
    }
    .report-info { flex: 1; min-width: 0; }
    .report-name { font-size: 13px; font-weight: 700; color: var(--black); }
    .report-desc { font-size: 11.5px; color: var(--gray-1); margin-top: 1px; }

    /* ── RECENT EXPORTS ────────────────────────────── */
    .export-row {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 20px;
      border-bottom: 1px solid var(--gray-3);
    }
    .export-row:last-child { border-bottom: none; }
    .export-icon-wrap {
      width: 32px; height: 32px;
      background: var(--gray-4);
      border-radius: var(--radius-sm);
      display: flex; align-items: center; justify-content: center;
      color: var(--gray-2);
      flex-shrink: 0;
    }
    .export-name { font-size: 12.5px; font-weight: 600; color: var(--black); }
    .export-date { font-size: 11px; color: var(--gray-2); margin-top: 1px; }
    .export-dl {
      margin-left: auto;
      display: flex; align-items: center; justify-content: center;
      width: 28px; height: 28px;
      border-radius: var(--radius-sm);
      border: 1.5px solid var(--gray-3);
      background: var(--white);
      color: var(--gray-1);
      cursor: pointer;
      transition: all .15s;
      flex-shrink: 0;
    }
    .export-dl:hover { border-color: var(--black); color: var(--black); }

    /* ── CAUTION STRIP ─────────────────────────────── */
    .caution-strip {
      height: 5px;
      background: repeating-linear-gradient(-55deg, var(--yellow) 0, var(--yellow) 10px, var(--black) 10px, var(--black) 20px);
      opacity: .15;
    }

    /* ── EMPTY STATE (coming soon) ─────────────────── */
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }
    .coming-soon {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 16px;
      padding: 80px 20px;
      background: var(--white);
      border: 1px solid var(--gray-3);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }
    .coming-soon-icon {
      width: 60px; height: 60px;
      background: var(--yellow-bg);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
    }
    .coming-soon-title { font-size: 16px; font-weight: 800; color: var(--black); }
    .coming-soon-desc { font-size: 13px; color: var(--gray-1); text-align: center; max-width: 320px; line-height: 1.6; }

    /* ── RESPONSIVE ────────────────────────────────── */
    @media (max-width: 1100px) {
      .two-col { grid-template-columns: 1fr; }
      .right-col { flex-direction: row; flex-wrap: wrap; }
      .right-col .card { flex: 1 1 280px; }
    }
    @media (max-width: 768px) {
      .stat-grid-4 { grid-template-columns: repeat(2, 1fr); }
      .content { padding: 16px; }
    }
  </style>
</head>

<body>

<!-- ═══════════════ SIDEBAR ═══════════════ -->
<aside class="sidebar">
  <div class="sidebar-logo">
    <img src="logo-white.png" alt="Caution Tape Robotics" />
    <div class="sidebar-logo-sub">Club Manager</div>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-section-label">General</div>
    <a class="nav-item" href="index.html">
      <i data-lucide="layout-dashboard"></i> Dashboard
    </a>
    <a class="nav-item" href="students.html">
      <i data-lucide="users"></i> Students
    </a>
    <a class="nav-item" href="foundation.html">
      <i data-lucide="book-open"></i> Foundation
    </a>
    <a class="nav-item" href="teams.html">
      <i data-lucide="cpu"></i> Teams
    </a>
    <a class="nav-item" href="tasks.html">
      <i data-lucide="circle-check"></i> Tasks
      <span class="nav-badge">5</span>
    </a>
    <a class="nav-item" href="projects.html">
      <i data-lucide="folder"></i> Projects
    </a>

    <div class="nav-section-label" style="margin-top:8px;">Competition</div>
    <a class="nav-item" href="https://matchsight.ct839.com/events?programId=1" target="_blank">
      <i data-lucide="trophy"></i> Competitions
    </a>

    <div class="nav-section-label" style="margin-top:8px;">Operations</div>
    <a class="nav-item" href="inventory.html">
      <i data-lucide="package"></i> Inventory
    </a>
    <a class="nav-item" href="purchases.html">
      <i data-lucide="receipt"></i> Purchases
    </a>
    <a class="nav-item" href="purchases-invoices.html">
      <i data-lucide="file-text"></i> Invoices
    </a>
    <a class="nav-item active" href="reports.html">
      <i data-lucide="bar-chart-2"></i> Reports
    </a>
    <div style="margin-top:auto;"></div>
    <a class="nav-item" href="#">
      <i data-lucide="settings"></i> Settings
    </a>
  </nav>

  <div class="sidebar-footer">
    <div class="sidebar-user">
      <div class="sidebar-avatar">
        <img src="icon-white.png" alt="User" />
      </div>
      <div style="flex:1;min-width:0;">
        <div class="sidebar-user-name">Malhar Soni</div>
        <div class="sidebar-user-role">Head Coach</div>
      </div>
      <i data-lucide="chevron-up" style="width:14px;height:14px;color:#737373;flex-shrink:0;"></i>
    </div>
  </div>
</aside>

<!-- ═══════════════ MAIN ═══════════════ -->
<div class="main">

  <!-- TOPBAR -->
  <header class="topbar">
    <div class="breadcrumb">
      <a href="index.html">Dashboard</a>
      <span class="breadcrumb-sep"><i data-lucide="chevron-right" style="width:13px;height:13px;"></i></span>
      <span class="breadcrumb-current">Reports</span>
    </div>
    <div class="search-wrap" style="margin-left:16px;">
      <i data-lucide="search" style="width:14px;height:14px;color:#A3A3A3;flex-shrink:0;"></i>
      <input type="text" placeholder="Search students, teams, events…" />
      <span class="search-kbd">⌘K</span>
    </div>
    <div class="topbar-right">
      <button class="btn btn-outline">
        <i data-lucide="calendar" style="width:13px;height:13px;"></i>
        2024–25 Season
        <i data-lucide="chevron-down" style="width:12px;height:12px;"></i>
      </button>
      <button class="btn btn-yellow" onclick="exportAll()">
        <i data-lucide="download" style="width:13px;height:13px;"></i>
        Export All
      </button>
      <div class="icon-btn" onclick="openNotifPanel()" style="position:relative;cursor:pointer;">
        <i data-lucide="bell" style="width:15px;height:15px;"></i>
        <span class="notif-dot"></span>
      </div>
    </div>
  </header>

  <!-- PAGE CONTENT -->
  <main class="content">

    <!-- PAGE HEADER -->
    <div class="page-header">
      <div>
        <div class="page-title">Reports</div>
        <div class="page-subtitle">Season analytics, attendance data, and downloadable exports for the club.</div>
      </div>
    </div>

    <!-- TABS -->
    <div class="tabs-wrap">
      <div class="tab-item active" onclick="switchTab('season')" id="tab-season">
        <i data-lucide="layout-dashboard" style="width:14px;height:14px;"></i>
        Season Summary
      </div>
      <div class="tab-item" onclick="switchTab('attendance')" id="tab-attendance">
