              </button>
            </div>

            <div class="export-row">
              <div class="export-icon-wrap">
                <i data-lucide="file-text" style="width:14px;height:14px;"></i>
              </div>
              <div>
                <div class="export-name">Attendance Report.pdf</div>
                <div class="export-date">Feb 10, 2026 &nbsp;·&nbsp; 842 KB</div>
              </div>
