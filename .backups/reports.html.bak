      <div class="tab-item" onclick="switchTab('students')" id="tab-students">
        <i data-lucide="user-check" style="width:14px;height:14px;"></i>
        Student Progress
      </div>
      <div class="tab-item" onclick="switchTab('competition')" id="tab-competition">
        <i data-lucide="trophy" style="width:14px;height:14px;"></i>
        Competition Results
